# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Comma-separated list of allowed GitHub user IDs
ALLOWED_GITHUB_IDS=12345,67890

# Docker settings (optional)
CONTAINER_IMAGE=pf-user-container:latest
CONTAINER_NETWORK=pf-internal

# Path settings (optional, see src/pf_server/config.py for defaults)
# DOCKER_BASE_CWD=/workdir
# DOCKER_PF_TOOLS_DIRECTORY=/pf-tools
# HOST_USERS_DATA_DIRECTORY=/home/ubuntu/pf_users_data
# HOST_PF_TOOLS_DIRECTORY=/home/ubuntu/csf/pytest_property_checker
